# Environment Configuration
ENVIRONMENT=<development or production>

# EmailJS Configuration
# Get these values from your EmailJS dashboard: https://www.emailjs.com/
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# Netlify Secret Scan Omit Keys (To bypass secret scanning for these keys)
SECRETS_SCAN_OMIT_KEYS=VITE_EMAILJS_PUBLIC_KEY,VITE_EMAILJS_SERVICE_ID,VITE_EMAILJS_TEMPLATE_ID,ENVIRONMENT

# Show Theme Menu in Header
showThemeMenu=true